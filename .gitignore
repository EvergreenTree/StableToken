# Experiment outputs are intentionally tracked when they are lightweight.
!experiments/**/*.csv
!experiments/**/*.tsv
!experiments/**/*.json
!experiments/**/*.png
!experiments/**/*.txt
!experiments/**/*.md

# Training smoke metadata is tracked; heavyweight checkpoints stay local.
experiments/training_runs/**
!experiments/training_runs/
!experiments/training_runs/**/
!experiments/training_runs/**/resolved_config.json
!experiments/training_runs/**/result.json
!experiments/training_runs/**/lfq_tokenizer_metadata.json
!experiments/training_runs/**/loss_curve.csv
!experiments/training_runs/**/loss_curve.png
!experiments/training_runs/**/README.md

# Matrix launch logs/PIDs stay local; commit lightweight summaries explicitly.
experiments/matrix_runs/**
!experiments/matrix_runs/
!experiments/matrix_runs/**/
!experiments/matrix_runs/**/*.json
!experiments/matrix_runs/**/*.csv
!experiments/matrix_runs/**/*.txt
!experiments/matrix_runs/**/*.md

